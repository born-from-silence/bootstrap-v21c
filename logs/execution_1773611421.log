# Function: Get last pulse from entity
get_pulse() {
    local entity=$1
    local pulse_file="/home/$entity/bootstrap/continuity/PULSE.md"
    
    if [ -f "$pulse_file" ]; then
        tail -1 "$pulse_file" 2>/dev/null | grep "PULSE" | cut -d'|' -f2
    else
